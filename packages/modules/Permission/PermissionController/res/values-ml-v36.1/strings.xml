<resources xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">
    <string name="permission_description_summary_contacts" msgid="2757597696923097587">"ഈ അനുമതിയുള്ള ആപ്പുകൾക്ക്, നിങ്ങളുടെ കോൺടാക്റ്റുകൾ ആക്സസ് ചെയ്യാനും ഈ ഉപകരണത്തിൽ കോൺടാക്റ്റുകൾ സംരക്ഷിക്കാനാകുന്ന അക്കൗണ്ടുകളുടെ ലിസ്റ്റ് കാണാനും കഴിയും"</string>
    <string name="permgrouprequest_contacts" msgid="4011412821869715229">"&lt;b&gt;<xliff:g id="APP_NAME">%1$s</xliff:g>&lt;/b&gt; എന്നതിനെ ഈ ഉപകരണത്തിലെ കോൺടാക്റ്റുകളും അക്കൗണ്ടുകളും ആക്സസ് ചെയ്യാൻ അനുവദിക്കണോ?"</string>
    <string name="permgrouprequestdetail_contacts" msgid="3314989542973932720">"ഈ ആപ്പിന് നിങ്ങളുടെ കോൺടാക്‌റ്റുകൾ ആക്‌സസ് ചെയ്യാനും കോൺടാക്‌റ്റുകൾ സംരക്ഷിക്കാനാകുന്ന അക്കൗണ്ടുകളുടെ ലിസ്‌റ്റ് കാണാനും കഴിയും"</string>
    <string name="permgrouprequest_device_aware_contacts" msgid="2668046201497840127">"&lt;b&gt;<xliff:g id="DEVICE_NAME">%2$s</xliff:g>&lt;/b&gt; എന്നതിലെ കോൺടാക്റ്റുകളും അക്കൗണ്ടുകളും ആക്സസ് ചെയ്യാൻ &lt;b&gt;<xliff:g id="APP_NAME">%1$s</xliff:g>&lt;/b&gt; എന്നതിനെ അനുവദിക്കണോ?"</string>
