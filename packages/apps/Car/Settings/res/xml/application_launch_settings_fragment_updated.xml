<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:settings="http://schemas.android.com/apk/res-auto"
    android:title="@string/app_launch_title"
    android:key="@string/psk_application_launch_settings">
    <com.android.car.settings.common.EntityHeaderPreference
        android:key="@string/pk_opening_links_app_details"
        settings:controller="com.android.car.settings.applications.managedomainurls.ApplicationWithVersionPreferenceController"
        settings:searchable="false"/>
    <com.android.car.settings.common.ColoredSwitchPreference
        android:key="@string/pk_opening_links_app_toggle"
        android:title="@string/app_launch_open_domain_urls_title"
        style="@style/ColoredSwitchPreferenceStyle"
        settings:controller="com.android.car.settings.applications.managedomainurls.OpenLinksSwitchPreferenceController"/>
    <com.android.car.ui.preference.CarUiPreference
        android:key="@string/pk_opening_links_verified_links"
        android:title="@string/opening_links_verified_links_title"
        settings:controller="com.android.car.settings.applications.managedomainurls.VerifiedLinksPreferenceController"/>
    <com.android.car.ui.preference.CarUiMultiSelectListPreference
        android:key="@string/pk_opening_links_supported_links"
        android:title="@string/opening_links_supported_links_title"
        settings:controller="com.android.car.settings.applications.managedomainurls.SelectedLinksListPreferenceController"/>
    <com.android.car.ui.preference.CarUiMultiSelectListPreference
        android:key="@string/pk_opening_links_add_links"
        android:title="@string/opening_links_add_links_title"
        settings:controller="com.android.car.settings.applications.managedomainurls.AddLinksListPreferenceController"/>
    <com.android.car.ui.preference.CarUiFooterPreference
        android:key="@string/pk_opening_links_footer_info"
        android:summary="@string/app_launch_footer"
        android:icon="@drawable/ic_settings_about"
        android:selectable="false"/>
</PreferenceScreen>
