    <string name="permission_description_summary_contacts" msgid="2757597696923097587">"जिन ऐप्लिकेशन के पास यह अनुमति है वे आपके संपर्कों को ऐक्सेस कर सकते हैं. साथ ही, इस डिवाइस पर मौजूद उन खातों की सूची देख सकते हैं जिनमें संपर्क सेव किए जा सकते हैं"</string>
    <string name="permgrouprequest_contacts" msgid="4011412821869715229">"क्या &lt;b&gt;<xliff:g id="APP_NAME">%1$s</xliff:g>&lt;/b&gt; को इस डिवाइस में मौजूद संपर्कों और खातों का ऐक्सेस देना है?"</string>
    <string name="permgrouprequestdetail_contacts" msgid="3314989542973932720">"यह ऐप्लिकेशन आपके संपर्कों को ऐक्सेस कर पाएगा. साथ ही, उन खातों की सूची देख पाएगा जिनमें संपर्क सेव किए जा सकते हैं"</string>
    <string name="permgrouprequest_device_aware_contacts" msgid="2668046201497840127">"क्या &lt;b&gt;<xliff:g id="APP_NAME">%1$s</xliff:g>&lt;/b&gt;को &lt;b&gt;<xliff:g id="DEVICE_NAME">%2$s</xliff:g>&lt;/b&gt; में मौजूद संपर्कों और खातों का ऐक्सेस देना है?"</string>
