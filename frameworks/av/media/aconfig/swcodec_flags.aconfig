# Media SW Codec Flags.
#
# !!! Please add flags in alphabetical order. !!!
package: "android.media.swcodec.flags"
container: "com.android.media.swcodec"

flag {
  name: "apexcodecs_base"
  # ApexCodecs API is getting called early in the boot process, so we need to make
  # sure that the flag value is stable from the early boot stage.
  is_fixed_read_only: true
  namespace: "codec_fwk"
  description: "Feature flag for base implementation of apexcodecs"
  bug: "401332082"
}

flag {
  name: "apv_software_codec"
  is_exported: true
  is_fixed_read_only: true
  namespace: "codec_fwk"
  description: "Feature flag for APV Software C2 codec"
  bug: "376770121"
}

flag {
  name: "avc_keep_threads_active"
  namespace: "codec_fwk"
  description: "Enable keep_threads_active in avc encoder"
  bug: "288998933"
}

flag {
  name: "dataspace_v0_gralloc4"
  is_exported: false
  is_fixed_read_only: true
  namespace: "codec_fwk"
  description: "Bugfix flag for using V0 dataspace in swcodec & gralloc4+"
  bug: "422682645"
  metadata {
    purpose: PURPOSE_BUGFIX
  }
}

flag {
  name: "iamf_aac_flac"
  is_exported: false
  is_fixed_read_only: true
  namespace: "codec_fwk"
  description: "Feature flag for enabling AAC and FLAC in the IAMF Software C2 decoder"
  bug: "396187214"
}

flag {
  name: "iamf_software_decoder"
  is_exported: false
  is_fixed_read_only: true
  namespace: "codec_fwk"
  description: "Feature flag for IAMF Software C2 decoder"
  bug: "388336285"
}

flag {
  name: "mpeg2_keep_threads_active"
  is_exported: true
  is_fixed_read_only: true
  namespace: "codec_fwk"
  description: "Enable keep_threads_active in mpeg2 decoder"
  bug: "343793479"
}
