package: "com.android.permissioncontroller.flags"
container: "com.android.permission"

flag {
    name: "grant_activity_pause_handover"
    namespace: "permissions"
    description: "This flag controls the onPause behavior in the grant activity, which handles a rare edge case when two dialogs start at the same time"
    bug: "420375604"
    metadata {
       purpose: PURPOSE_BUGFIX
    }
}
