    xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">
    <string name="permission_description_summary_contacts" msgid="2757597696923097587">"ಈ ಅನುಮತಿಯನ್ನು ಹೊಂದಿರುವ ಆ್ಯಪ್‌ಗಳು ನಿಮ್ಮ ಸಂಪರ್ಕಗಳನ್ನು ಆ್ಯಕ್ಸೆಸ್ ಮಾಡಬಹುದು ಮತ್ತು ಈ ಸಾಧನದಲ್ಲಿ ಸಂಪರ್ಕಗಳನ್ನು ಸೇವ್ ಮಾಡಬಹುದಾದ ಖಾತೆಗಳ ಪಟ್ಟಿಯನ್ನು ನೋಡಬಹುದು"</string>
    <string name="permgrouprequest_contacts" msgid="4011412821869715229">"ಈ ಸಾಧನದಲ್ಲಿ ಸಂಪರ್ಕಗಳು ಮತ್ತು ಖಾತೆಗಳನ್ನು ಆ್ಯಕ್ಸೆಸ್ ಮಾಡಲು &lt;b&gt;<xliff:g id="APP_NAME">%1$s</xliff:g>&lt;/b&gt; ಗೆ ಅನುಮತಿಸಬೇಕೇ?"</string>
    <string name="permgrouprequestdetail_contacts" msgid="3314989542973932720">"ಈ ಆ್ಯಪ್‌ಗೆ ನಿಮ್ಮ ಸಂಪರ್ಕಗಳನ್ನು ಆ್ಯಕ್ಸೆಸ್ ಮಾಡಲು ಮತ್ತು ಸಂಪರ್ಕಗಳನ್ನು ಸೇವ್ ಮಾಡಬಹುದಾದ ನಿಮ್ಮ ಖಾತೆಗಳ ಪಟ್ಟಿಯನ್ನು ನೋಡಲು ಸಾಧ್ಯವಾಗುತ್ತದೆ"</string>
    <string name="permgrouprequest_device_aware_contacts" msgid="2668046201497840127">"&lt;b&gt;<xliff:g id="DEVICE_NAME">%2$s</xliff:g>&lt;/b&gt; ನಲ್ಲಿ ಸಂಪರ್ಕಗಳು ಮತ್ತು ಖಾತೆಗಳನ್ನು ಆ್ಯಕ್ಸೆಸ್ ಮಾಡಲು &lt;b&gt;<xliff:g id="APP_NAME">%1$s</xliff:g>&lt;/b&gt; ಗೆ ಅನುಮತಿಸಬೇಕೇ?"</string>
