    <style name="ExpressiveOutlineActionButton"
        parent="@style/Banner.NegativeButton.SettingsLib.Expressive">
        <item name="android:textColor">?attr/textColorScSecondaryActionButton</item>
    </style>
    <style name="ExpressiveOutlineActionButton.Fixed" />
    <style name="ExpressiveOutlineActionButton.Responsive" />
</resources>
